# Supabase — create a project at https://supabase.com and copy these from
# Project Settings -> API. Leave blank to run the app in built-in DEMO mode.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Set to "true" to force the in-memory demo dataset even if Supabase is configured.
NEXT_PUBLIC_DEMO_MODE=false
